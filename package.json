{
  "name": "moonlight-webapp",
  "version": "0.1.0",
  "private": true,
  "description": "Progressive Web App client for Moonlight (NVIDIA GameStream / Sunshine)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host",
    "wasm": "bash wasm/build.sh",
    "wasm:clean": "rm -rf wasm/build && rm -f public/wasm/moonlight.{js,wasm}",
    "typecheck": "tsc -b --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.21.0"
  }
}
